# rhel-oe-build-lab inventory
#
# Hosts in [production] are managed by the baseline_hardening,
# quarterly update, and validation playbooks.
#
# Notes
# -----
# - ansible_user is 'admin' (CRQ-002 complete). The admin account is
#   created by the users role with a passwordless sudo drop-in.
#   Root SSH is disabled fleet-wide. See change-records/CRQ-002.
# - Hostnames assume DNS or /etc/hosts entries on the control node.

[production]
servera
serverb
serverc
serverd

[all:vars]
ansible_user=admin
ansible_become=true
